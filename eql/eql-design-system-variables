  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: #0e0e11;
    color: #e0dfd8;
    padding: 48px 56px 80px;
    font-size: 13px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    max-width: 1200px;
  }

  .header {
    margin-bottom: 48px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .header h1 {
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: #fff;
  }
  .header p {
    font-size: 13px;
    color: #777;
    margin-top: 6px;
  }

  .collection-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #444;
    margin-bottom: 6px;
    margin-top: 56px;
  }

  .section {
    margin-bottom: 36px;
  }
  .section-title {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6e6aff;
    margin-bottom: 14px;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12.5px;
    margin-bottom: 8px;
  }
  thead th {
    text-align: left;
    font-size: 10.5px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #666;
    padding: 0 16px 10px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  tbody td {
    padding: 9px 16px 9px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    vertical-align: top;
  }
  tbody tr:last-child td { border-bottom: none; }

  .var-name {
    font-weight: 500;
    color: #fff;
    white-space: nowrap;
  }
  .val {
    font-family: 'DM Mono', monospace;
    font-size: 12px;
    color: #b8b6ad;
  }
  .val-rem {
    color: #555;
    font-size: 11px;
  }
  .fluid-yes {
    color: #4ade80;
    font-size: 11px;
    font-weight: 500;
  }
  .fluid-no {
    color: #555;
    font-size: 11px;
  }
  .formula {
    font-family: 'DM Mono', monospace;
    font-size: 10.5px;
    color: #555;
    word-break: break-all;
    max-width: 520px;
  }

  /* Color swatches */
  .color-row td:first-child { width: 200px; }
  .swatch {
    display: inline-block;
    width: 16px;
    height: 16px;
    border-radius: 4px;
    vertical-align: middle;
    margin-right: 8px;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .swatch-transparent {
    background: repeating-conic-gradient(#333 0% 25%, #555 0% 50%) 50% / 8px 8px;
  }

  .weight-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px 24px;
  }
  .weight-item {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .weight-label { color: #999; }
  .weight-val {
    font-family: 'DM Mono', monospace;
    color: #b8b6ad;
  }

  .note {
    margin-top: 40px;
    padding: 16px 20px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    font-size: 12px;
    color: #777;
    line-height: 1.7;
  }
  .note strong { color: #999; }

  hr.divider {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.06);
    margin: 48px 0 8px;
  }
</style>
